# Contoh konfigurasi produksi. Salin ke `.env` lalu isi nilai aslinya.
# JANGAN commit file `.env` (sudah di-ignore).
#
# Buat nilai rahasia yang kuat:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# Password halaman /admin (1 password bersama).
ADMIN_PASSWORD=ganti-dengan-password-kuat

# Token yang disisipkan ke form & divalidasi di POST /api/submit.
SUBMIT_TOKEN=ganti-dengan-token-acak

# Secret key untuk session Flask (login admin).
FLASK_SECRET_KEY=ganti-dengan-secret-acak-panjang

# URL publik lengkap TERMASUK sub-path. Dipakai untuk:
#   - link unduh collector, dan
#   - di-bake ke file collector saat diunduh (agar membuka form di server ini).
SERVER_BASE_URL=https://mtani.demosiapp.com/laptop-inventory

# Lokasi file SQLite (folder harus writable oleh user service / www-data).
DB_PATH=/var/www/laptop-inventory/data/inventory.db
